
{
    "layer": "top",

    "position": "top",

    "height": 30,

    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "sway/window"
    ],
    "modules-center": [

    ],
    "modules-right": [
        "network",
        "memory",
        "cpu",
        "sway/language",
        "battery",
        "tray",
        "clock#date",
        "clock#time"
    ],


    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "яГз  {icon}  {capacity}%",
        "format-discharging": "{icon}  {capacity}%",
        "format-icons": [
            "яЙД",
            "яЙГ",
            "яЙВ",
            "яЙБ",
            "яЙА" 
        ], 
        "tooltip": true
    },

    "clock#time": {
        "interval": 1,
        "format": "{:%H:%M:%S}",
        "tooltip": false,
	"on-click": "swaync-client --toggle-panel",
    },

    "clock#date": {
      "interval": 10,
      "format": "яБ│  {:%e %b %Y}",
      "tooltip-format": "{:%e %B %Y}"
    },

    "cpu": {
        "interval": 5,
        "format": "яЛЫ  {usage}% ({load})",
        "states": {
          "warning": 70,
          "critical": 90
        }
    },

    "sway/language": {
    	"format": "яДЬ {long}",
    },

    "memory": {
        "interval": 5,
        "format": "ю┐Е  {}%",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "network": {
        "interval": 5,
        "format-wifi": "яЗл  {essid} ({signalStrength}%)", 
        "format-ethernet": "яЮЦ  {ifname}: {ipaddr}/{cidr}", 
        "format-disconnected": "тЪа  Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}"
    },

    "sway/mode": {
        "format": "<span style=\"italic\">яМЮ  {}</span>", 
        "tooltip": false
    },

    "sway/window": {
        "format": "{}",
        "max-length": 50
    },

    "sway/workspaces": {
        "all-outputs": false,
        "disable-scroll": true,
        "format": "{icon} {name}",
        "format-icons": {
            "1:www": "ядЗ",
            "2:mail": "яК╢",
            "3:editor": "яДб", 
            "4:terminals": "яДа",
            "5:portal": "яДа", 
            "urgent": "яБк",
            "focused": "яЖТ",
            "default": "яДС"
        }
    },

    "temperature": {
      "critical-threshold": 80,
      "interval": 5,
      "format": "{icon}  {temperatureC}┬░C",
      "format-icons": [
          "яЛЛ", 
          "яЛК", 
          "яЛЙ", 
          "яЛИ", 
          "яЛИ"  
      ],
      "tooltip": true
    },

    "tray": {
        "icon-size": 21,
        "spacing": 10
    }

}
